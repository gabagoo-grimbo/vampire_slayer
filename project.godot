config_version=5

[addons]

imgui/config="uid://do7xsiwhq3c4d"

[application]

config/name="Vampire Slayer"
run/main_scene="uid://bbdcbielxuj0i"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Global="*uid://cu8kq38c6pjls"

[debug]

gdscript/warnings/untyped_declaration=1

[display]

window/size/viewport_width=384
window/size/viewport_height=216
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[dotnet]

project/assembly_name="Vampire Quest"

[file_customization]

folder_colors={
"res://assets/": "red",
"res://objects/": "yellow",
"res://resources/": "green",
"res://scenes/": "blue",
"res://scripts/": "purple"
}

